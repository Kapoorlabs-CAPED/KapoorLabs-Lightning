# Copy to secrets.toml and fill in real ORCID OAuth credentials.
# The same ORCID app can be reused across kapoorlabs.fr/Oneat and
# /Inception — register both redirect_uri values on the ORCID developer
# tools page.

[orcid]
client_id = "APP-XXXXXXXXXXXXXXXX"
client_secret = "00000000-0000-0000-0000-000000000000"
# Must match exactly what is registered on ORCID developer tools.
redirect_uri = "https://kapoorlabs.fr/Inception"
